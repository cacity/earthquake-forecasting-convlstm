{
  "model": {
    "name": "ConvLSTM",
    "input_channels": 10,
    "hidden_channels": 64,
    "kernel_size": 3,
    "num_layers": 1,
    "output_channels": 1
  },
  "data": {
    "catalog": "CENC user-provided local files; not included in this repository",
    "region": {
      "lon_min": 95.0,
      "lon_max": 110.0,
      "lat_min": 22.0,
      "lat_max": 35.0
    },
    "time_range": {
      "start": "2000-01-01",
      "end_exclusive": "2026-01-01"
    },
    "magnitude_threshold": 4.0,
    "depth_policy": "include depth=0 or missing depth; exclude known depth > 70 km",
    "grid_size_degrees": 1.0,
    "grid_shape": {
      "height": 13,
      "width": 15,
      "cells": 195
    },
    "lookback_months": 12,
    "forecast_horizon_months": 1,
    "features": [
      "count_norm",
      "max_mag_norm",
      "log_energy",
      "b_value",
      "mean_mag",
      "mag_std",
      "mean_depth",
      "recency_weight",
      "rate_change",
      "spatial_density"
    ]
  },
  "training": {
    "epochs": 50,
    "batch_size": 16,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "optimizer": "AdamW",
    "loss": "weighted_bce",
    "pos_weight_cap": 100.0,
    "grad_clip": 1.0,
    "early_stopping": {
      "patience": 5,
      "metric": "validation_loss"
    },
    "threshold_scan": "0.01:0.95:0.01",
    "seed": 42
  },
  "split": {
    "train_targets": "2001-01 through 2018-12",
    "validation_targets": "2019-01 through 2022-12",
    "test_targets": "2023-01 through 2025-12"
  },
  "evaluation": {
    "metrics": [
      "roc_auc",
      "pr_auc",
      "brier_score",
      "log_loss",
      "topk_alarm",
      "f1_at_validation_threshold"
    ],
    "bootstrap": {
      "method": "monthly_block",
      "n_iterations": 1000,
      "confidence_level": 0.95,
      "seed": 42
    },
    "baselines": [
      "SPR",
      "Persistence",
      "KDE",
      "DAR"
    ]
  }
}
